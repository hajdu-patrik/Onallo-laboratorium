@AutoService_ApiService_HostAddress = https://localhost:5200

# ─────────────────────────────────────────────────────────────
#  AUTH – Full API Test Matrix
#  End-to-end coverage for registration, normalization, duplicates,
#  invalid inputs, login variants, refresh and logout lifecycle.
# ─────────────────────────────────────────────────────────────

@TestPassword = Test@1234
@TestWrongPassword = WrongPassword123!

# Dedicated matrix users
@MatrixRunSuffix = 20260403a
@MatrixEmailOnly = matrix.email.only.{{MatrixRunSuffix}}@example.com
@MatrixEmailWithPhone = matrix.phone.user.{{MatrixRunSuffix}}@example.com
@MatrixPhoneCanonical = 36307770991
@MatrixWhitespaceEmail = matrix.whitespace.user.{{MatrixRunSuffix}}@example.com
@MatrixWhitespacePhoneCanonical = 36308880991
@DemoMechanicPhoneCanonical = 36301112233

# NOTE:
# If a positive register/login test starts failing with 401 because the account
# already exists from an earlier run with a different password, change MatrixRunSuffix.

### [Positive][Register] Email-only mechanic registration
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Matrix",
  "lastName": "EmailOnly",
  "email": "{{MatrixEmailOnly}}",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Positive][Register] Mechanic registration with phone (spaced 06 format)
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Matrix",
  "lastName": "PhoneUser",
  "email": "{{MatrixEmailWithPhone}}",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "phoneNumber": "06 30 777 0001",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Positive][Register] Mechanic registration with leading/trailing whitespace in email and phone
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Matrix",
  "lastName": "Whitespace",
  "email": "   MATRIX.WHITESPACE.USER.20260403A@EXAMPLE.COM   ",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "phoneNumber": "   +36 30 888 0991   ",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Negative][Register] Duplicate email with different phone
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Duplicate",
  "lastName": "Email",
  "email": "{{MatrixEmailWithPhone}}",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "phoneNumber": "+36309998888",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Negative][Register] Duplicate phone in another valid input format
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Duplicate",
  "lastName": "Phone",
  "email": "duplicate.phone@example.com",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "phoneNumber": "+36 30 777 0991",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Negative][Register] Duplicate phone with leading/trailing whitespace
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Duplicate",
  "lastName": "PhoneWhitespace",
  "email": "duplicate.phone.whitespace@example.com",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "phoneNumber": "   06 30 777 0991   ",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Negative][Register] Invalid email format
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
